{
  "name": "@plantbase/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@plantbase/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "nx": {
    "targets": {
      "generate": {
        "command": "pnpm exec prisma generate --schema packages/db/prisma/schema.prisma"
      },
      "migrate": {
        "command": "pnpm exec prisma migrate dev --schema packages/db/prisma/schema.prisma"
      },
      "seed": {
        "command": "pnpm exec prisma db seed"
      }
    }
  }
}
