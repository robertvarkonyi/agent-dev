# Plantbase — környezeti változók. Másold `.env`-be és töltsd ki.
# A .env NINCS a repóban (gitignore); csak a .env.example követett.

# --- Postgres (docker-compose) ---
POSTGRES_USER=plantbase
POSTGRES_PASSWORD=change-me-local
POSTGRES_DB=plantbase
POSTGRES_PORT=5432
# read-only role (az agent runSql-je ezt használja)
POSTGRES_RO_USER=plantbase_ro
POSTGRES_RO_PASSWORD=change-me-ro-local

# --- Kapcsolatok ---
# read-write: Prisma (séma, migráció, seed). Owner = POSTGRES_USER.
DATABASE_URL=postgresql://plantbase:change-me-local@localhost:5432/plantbase?schema=public
# read-only: az agent runSql-je (csak SELECT). = POSTGRES_RO_USER.
DATABASE_URL_READONLY=postgresql://plantbase_ro:change-me-ro-local@localhost:5432/plantbase?schema=public

# --- Anthropic (a B fázisokhoz) ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
