{
  "name": "@plantbase/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "cli": "NODE_OPTIONS=--conditions=@plantbase/source tsx apps/cli/src/main.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,mts,cts,mjs,cjs}": [
      "eslint --fix --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,yml,yaml}": [
      "prettier --write"
    ]
  },
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "prisma": {
    "seed": "tsx packages/db/prisma/seed.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nx/esbuild": "23.0.1",
    "@nx/js": "23.0.1",
    "@nx/node": "23.0.1",
    "@nx/vite": "23.0.1",
    "@nx/vitest": "23.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.18",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "~4.1.0",
    "dotenv": "^17.4.2",
    "esbuild": "^0.27.0",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.1",
    "nx": "23.0.1",
    "prettier": "^3.8.1",
    "prisma": "^6.19.3",
    "tslib": "^2.3.0",
    "tsx": "^4.22.4",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.0.0",
    "vitest": "~4.1.0"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3"
  }
}
